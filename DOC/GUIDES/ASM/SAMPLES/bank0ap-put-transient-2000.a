; BANK0AP-PUT-TRANSIENT-2000.A
; STANDARD BANK 0 AP INSTALLER; DIRECT-RUN OR FIXED-LOAD AP.
;
; INPUT:
;   AP CAPSULE AT PKG_BASE, DEFAULT AIR ENVELOPE BAY $3000 FROM
;   SEAL> PACKAGE $3000
;   DO NOT USE PACKAGE $2000 FOR THIS TOOL
;
; DIRECT RUN:
;   PASTE THIS SOURCE
;   SEAL> .
;   >G 2000
;
; BOOTSTRAP ITS OWN RESIDENT COPY:
;   SEAL> PACKAGE $3000
;   SEAL> .
;   >G 2000
;   RECORD THE PRINTED BANK-0 ADDRESS AS $PUTPKG
;
; LATER, WITH A TARGET PACKAGE AT $3000, RUN THE RESIDENT COPY WITH:
;   >AP B0 $PUTPKG $2000
; $PUTPKG IS THIS INSTALLER'S BANK-0 CAPSULE ADDRESS. $2000 IS
; ITS REQUIRED RAM LOAD ADDRESS. THE TARGET CAPSULE REMAINS AT $3000.
;
; FLOW:
;   VALIDATE -> STAGE -> APPEND-SCAN -> SHOW DESTINATION -> TYPE YES
;   -> PROGRAM/VERIFY. PRESS ENTER AT DST PROMPT FOR AUTO APPEND.
;
; THIS FIXED-LOAD AP EMITS IN THE AIR BUILD BAY AT $2000, USES THE SSD
; AT $0A00-$19FF AS THE STAGED SECTOR, AND LEAVES PKG_BASE UNCHANGED.
; INTERNAL ABSOLUTE CALLS AND
; TEXT POINTERS ARE LITERAL SO THE PACKAGE DOES NOT TRUNCATE RELOCS.
; ITS THREE HIMON I/O CALLS ARE CURRENT-IMAGE ADDRESSES SO THE SAME BODY
; CAN BOOTSTRAP WITH G 2000; REBUILD IT AFTER HIMON ADDRESS CHANGES.
; STARTING THE FLASH WORKER INVALIDATES ASM'S LOW-RAM NAME TABLES.
; AUTO follows complete AP/01 envelope lengths and appends only in a clean
; erased tail of a sector. It never reuses an interior $FF run. AUTO may move
; to the next sector only when the current sector is closed or its clean tail
; is too short. The trace says why.
;
; APPENDSCAN'S ENTRY, CLOSE PATH, AND TEXT POINTERS BELOW ARE FIXED $2000
; LITERALS. THAT KEEPS THIS PACKAGE AT SEAL REL COUNT=$00. IF ITS SIZE OR
; LAYOUT CHANGES, RECALCULATE THOSE LITERALS BEFORE PACKAGING IT.
;
; STATUS:
;   $1A00 = $AC PROGRAM/VERIFY OK
;   $1A00 = $E0 ABORTED BEFORE WRITE
;   $1A00 = $E1 BAD AP HEADER/LENGTH AT PKG_BASE
;   $1A00 = $E2 BAD DEST/LEN OR CROSSES 4K SECTOR
;   $1A00 = $E3 NO ERASED BANK-0 HOLE FITS
;   $1A00 = $E4 STAGE-COPY FAILED
;   $1A00 = $E5 DESTINATION RANGE IS NOT ERASED
;   $1A00 = $E6 PROGRAM/VERIFY FAILED
;   $1A00 = $E7 STAGED AP CHECK FAILED
;   $1A01/$1A02 = SELECTED BANK-0 PACKAGE ADDRESS, LO/HI
;   $1A03/$1A04 = AP ENVELOPE LENGTH, LO/HI
;   $1A05 = SELECTED SECTOR HIGH BYTE
;   $1A06 = $00 AFTER RETURN
;   $1A07-$1A0D = VOLATILE AUTO-SCAN CURSOR/LENGTH/TAIL/TRACE STATE

PKG_BASE EQU $3000
PKG     EQU PKG_BASE
PKG1    EQU PKG_BASE+1
PKG3    EQU PKG_BASE+3
PKG4    EQU PKG_BASE+4

STAT    EQU $1A00
DSTLO   EQU $1A01
DSTHI   EQU $1A02
LENLO   EQU $1A03
LENHI   EQU $1A04
SECHI   EQU $1A05
READY   EQU $1A06
INBUF   EQU $1A10
INB1    EQU $1A11
INB2    EQU $1A12
INB3    EQU $1A13

CURLO   EQU $1A07
CURHI   EQU $1A08
CANLO   EQU $1A09
CANHI   EQU $1A0A
ATRACE  EQU $1A0B
TAILLO  EQU $1A0C
TAILHI  EQU $1A0D

SPLO    EQU $C8
SPHI    EQU $C9
DPLO    EQU $CA
DPHI    EQU $CB
CNTLO   EQU $CC
CNTHI   EQU $CD

        ORG $2000

; KEEP TEXT BEFORE CODE: ITS 20 ADDRESS USES THEN NEED NO FIXUP ROWS.
BANK0_AP_PUT JMP $20E3
        ENTRY BANK0_AP_PUT

MTITLE  DB $0D,$0A,'B','0',' ','A','P',' ','P','U','T'
        DB $0D,$0A,0
MPKG    DB 'P','K','G',' ','L','=','$',0
MDST    DB 'D','S','T',' ','$','8','0','0','0'
        DB '-','$','F','F','F','F',' ','O','R',' '
        DB 'E','N','T','E','R','=','A','U','T','O'
        DB '>',' ',0
MSEL    DB 'B','0',' ','A','P',' ','@','$',0
MLEN    DB ' ','L','=','$',0
MSTAGED DB 'S','T','A','G','E',' ','O','K',$0D,$0A,0
MCONF   DB 'T','Y','P','E',' ','Y','E','S'
        DB ' ','T','O',' ','W','R','I','T','E','>',' ',0
MOK     DB 'P','R','O','G','R','A','M',' ','O','K',$0D,$0A,0
MFAIL   DB 'F','A','I','L',' ','$','1','A','0','0','=','$',0
MABORT  DB 'A','B','O','R','T',' ','-',' ','N','O',' '
        DB 'F','L','A','S','H',' ','W','R','I','T','E'
        DB $0D,$0A,0

READ    LDX #<INBUF
        LDY #>INBUF
        JMP SYS_READ_CSTRING_ECHO_UPPER

PUTS    JMP BIO_FTDI_PUT_CSTR

H2N     CMP #'0'
        BCC .BAD
        CMP #':'
        BCC .DIG
        CMP #'A'
        BCC .BAD
        CMP #'G'
        BCS .BAD
        SEC
        SBC #$37
        SEC
        RTS
.DIG    SEC
        SBC #'0'
        SEC
        RTS
.BAD    CLC
        RTS

HEX     PHA
        LSR A
        LSR A
        LSR A
        LSR A
        JSR $20CA
        PLA
        AND #$0F
.NIB    CMP #$0A
        BCC .DIG
        CLC
        ADC #$37
        BRA OUT
.DIG    CLC
        ADC #'0'
OUT     JMP BIO_FTDI_WRITE_BYTE_BLOCK

CRLF    LDA #$0D
        JSR $20D6
        LDA #$0A
        JMP $20D6

RUN     STZ STAT
        STZ DSTLO
        STZ DSTHI
        STZ LENLO
        STZ LENHI
        STZ SECHI
        STZ READY
        LDX #$03
        LDY #$20
        JSR $20A0
        JSR $21DE
        BCS .PKGOK
        JMP $21C3

.PKGOK  JSR $2203
        BCS .LENOK
        JMP $21C3

.LENOK  LDX #$11
        LDY #$20
        JSR $20A0
        LDA LENHI
        JSR $20BF
        LDA LENLO
        JSR $20BF
        JSR $20D9

.ASKDST LDX #$19
        LDY #$20
        JSR $20A0
        JSR $2099
        BCS .HAVEDST
        LDA #$E2
        JMP $21C3

.HAVEDST CMP #$00
        BNE .PARSEDST
        JSR $2278
        BCS .CHOSEN
        JMP $21C3

.PARSEDST JSR $2217
        BCS .USERDST
        LDA #$E2
        JMP $21C3

.USERDST JSR $226F
        JSR $22A2
        BCS .STAGED
        JMP $21C3

.STAGED JSR $2344
        BCS .CHOSEN
        JMP $21C3

.CHOSEN JSR $2370
        LDA #$5A
        STA READY
        JSR $2399
        BCS .READY
        JMP $21C3

.READY  LDX #$47
        LDY #$20
        JSR $20A0
        JSR $2431
        LDX #$52
        LDY #$20
        JSR $20A0
        JSR $2099
        BCS .GOT
        JMP $21AF

.GOT    JSR $2401
        BCS .WRITE
        JMP $21AF

.WRITE  JSR $23E1
        BCS DONE
        JMP $21C3

DONE    LDA #$AC
        STA STAT
        STZ READY
        LDX #$66
        LDY #$20
        JSR $20A0
        JSR $2431
        LDA STAT
        SEC
        RTS

ABORT   LDA #$E0
        STA STAT
        STZ READY
        LDX #$80
        LDY #$20
        JSR $20A0
        LDA STAT
        CLC
        RTS

FAILA   STA STAT
        STZ READY
        LDX #$73
        LDY #$20
        JSR $20A0
        LDA STAT
        JSR $20BF
        JSR $20D9
        LDA STAT
        CLC
        RTS

READPKG LDA PKG
        CMP #'A'
        BNE .BAD
        LDA PKG1
        CMP #'P'
        BNE .BAD
        LDA PKG3
        STA LENLO
        LDA PKG4
        STA LENHI
        ORA LENLO
        BNE .GOOD
.BAD    LDA #$E1
        CLC
        RTS
.GOOD   SEC
        RTS

CHECKLEN LDA LENHI
        CMP #$10
        BCC .GOOD
        BNE .BAD
        LDA LENLO
        BEQ .GOOD
.BAD    LDA #$E2
        CLC
        RTS
.GOOD   SEC
        RTS

PARADDR LDX #$00
        LDA INBUF,X
        CMP #'$'
        BNE .PHEX0
        INX
.PHEX0  LDA INBUF,X
        JSR $20A3
        BCC .BAD
        ASL A
        ASL A
        ASL A
        ASL A
        STA DSTHI
        INX
        LDA INBUF,X
        JSR $20A3
        BCC .BAD
        ORA DSTHI
        STA DSTHI
        INX
        LDA INBUF,X
        JSR $20A3
        BCC .BAD
        ASL A
        ASL A
        ASL A
        ASL A
        STA DSTLO
        INX
        LDA INBUF,X
        JSR $20A3
        BCC .BAD
        ORA DSTLO
        STA DSTLO
        INX
        LDA INBUF,X
        BNE .BAD
        LDA DSTHI
        CMP #$80
        BCC .BAD
        SEC
        RTS
.BAD    CLC
        RTS

SETSECTOR LDA DSTHI
        AND #$F0
        STA SECHI
        RTS

FINDHOLE LDA #$80
        STA SECHI
.LOOP   STZ DSTLO
        LDA SECHI
        STA DSTHI
        JSR $22A2
        BCS .STAGED
        RTS
.STAGED JSR $245B             ; APPENDSCAN
        BCS .OK
        LDA SECHI
        CLC
        ADC #$10
        STA SECHI
        BNE .LOOP
        LDA #$E3
        CLC
        RTS
.OK     SEC
        RTS

STAGE   LDA #$00
        STA $1FEE
        LDA SECHI
        STA $1FE9
        LDA #$0A
        STA $1FF6
        LDA #$06
        STA $1FF0
        JSR $F003
        BCS .OK
        LDA #$E4
        CLC
        RTS
.OK     SEC
        RTS

SCANHOLE STZ SPLO
        LDA #$0A
        STA SPHI
        STZ CNTLO
        STZ CNTHI
.LOOP   LDA SPHI
        CMP #$1A
        BNE .IN
        CLC
        RTS
.IN     LDY #$00
        LDA (SPLO),Y
        CMP #$FF
        BEQ .FF
        STZ CNTLO
        STZ CNTHI
        JSR $2322
        BRA .LOOP
.FF     LDA CNTLO
        ORA CNTHI
        BNE .COUNT
        LDA SPLO
        STA DSTLO
        LDA SPHI
        SEC
        SBC #$0A
        CLC
        ADC SECHI
        STA DSTHI
.COUNT  INC CNTLO
        BNE .FIT
        INC CNTHI
.FIT    JSR $230E
        BCS .OK
        JSR $2322
        BRA .LOOP
.OK     SEC
        RTS

RUNFITS LDA CNTHI
        CMP LENHI
        BCC .NO
        BNE .YES
        LDA CNTLO
        CMP LENLO
        BCC .NO
.YES    SEC
        RTS
.NO     CLC
        RTS

INCSP   INC SPLO
        BNE .DONE
        INC SPHI
.DONE   RTS

SETSTAGEPTR LDA DSTLO
        STA DPLO
        LDA DSTHI
        AND #$0F
        CLC
        ADC #$0A
        STA DPHI
        RTS

SETCOUNT LDA LENLO
        STA CNTLO
        LDA LENHI
        STA CNTHI
        RTS

CHECKHOLE JSR $2329
        JSR $2339
.LOOP   LDA CNTLO
        ORA CNTHI
        BEQ .OK
        LDA DPHI
        CMP #$1A
        BCC .ADDR
        LDA #$E2
        CLC
        RTS
.ADDR   LDY #$00
        LDA (DPLO),Y
        CMP #$FF
        BNE .USED
        JSR $241F
        JSR $2426
        BRA .LOOP
.USED   LDA #$E5
        CLC
        RTS
.OK     SEC
        RTS

COPYPKG LDA #$00
        STA SPLO
        LDA #$30
        STA SPHI
        JSR $2329
        JSR $2339
.LOOP   LDA CNTLO
        ORA CNTHI
        BEQ .DONE
        LDY #$00
        LDA (SPLO),Y
        STA (DPLO),Y
        INC SPLO
        BNE .DST
        INC SPHI
.DST    JSR $241F
        JSR $2426
        BRA .LOOP
.DONE   RTS

CHECKSTAGE LDA READY
        CMP #$5A
        BNE .BAD
        LDA DSTHI
        CMP #$80
        BCC .BAD
        LDA LENLO
        ORA LENHI
        BEQ .BAD
        LDA SECHI
        CMP #$80
        BCC .BAD
        JSR $2329
        LDY #$00
        LDA (DPLO),Y
        CMP #'A'
        BNE .BAD
        LDY #$01
        LDA (DPLO),Y
        CMP #'P'
        BNE .BAD
        LDY #$03
        LDA (DPLO),Y
        CMP LENLO
        BNE .BAD
        LDY #$04
        LDA (DPLO),Y
        CMP LENHI
        BNE .BAD
        SEC
        RTS
.BAD    LDA #$E7
        CLC
        RTS

PROGRAM LDA #$00
        STA $1FEF
        LDA SECHI
        STA $1FE9
        LDA #$0A
        STA $1FF6
        LDA #$05
        STA $1FF0
        JSR $F003
        BCS .OK
        LDA #$E6
        CLC
        RTS
.OK     SEC
        RTS

ISYES   LDA INBUF
        CMP #'Y'
        BNE .NO
        LDA INB1
        CMP #'E'
        BNE .NO
        LDA INB2
        CMP #'S'
        BNE .NO
        LDA INB3
        BNE .NO
        SEC
        RTS
.NO     CLC
        RTS

INCDP   INC DPLO
        BNE .DONE
        INC DPHI
.DONE   RTS

DECCNT  DEC CNTLO
        LDA CNTLO
        CMP #$FF
        BNE .DONE
        DEC CNTHI
.DONE   RTS

PRINTDST LDX #$39
        LDY #$20
        JSR $20A0
        LDA DSTHI
        JSR $20BF
        LDA DSTLO
        JSR $20BF
        LDX #$42
        LDY #$20
        JSR $20A0
        LDA LENHI
        JSR $20BF
        LDA LENLO
        JSR $20BF
        JSR $20D9
        RTS

; ---------------------------------------------------------------------------
; APPENDSCAN
; IN : $0A00-$19FF = staged Bank-0 sector, SECHI = sector high byte.
;      LENLO/LENHI = requested AP envelope length.
; OUT: C=1 and DSTLO/DSTHI = append location, or C=0 when this sector is
;      closed or its clean tail is too short. A trace row is always printed.
; NOTE: Each occupied item must begin AP/01 and its declared length must end
;       in this sector. This is deliberately conservative framing validation:
;       malformed data closes the sector rather than being treated as a hole.
; ---------------------------------------------------------------------------
APPENDSCAN STZ CURLO
        STZ CURHI
.LOOP   LDA CURHI
        CMP #$10
        BCS .EARLYCLOSE

        LDA CURLO
        STA SPLO
        LDA CURHI
        CLC
        ADC #$0A
        STA SPHI

        LDY #$00
        LDA (SPLO),Y
        CMP #$FF
        BEQ .TAIL
        CMP #'A'
        BNE .EARLYCLOSE
        INY
        LDA (SPLO),Y
        CMP #'P'
        BNE .EARLYCLOSE
        INY
        LDA (SPLO),Y
        CMP #$01
        BNE .EARLYCLOSE

        ; A five-byte header may not start in the final four sector bytes.
        LDA CURHI
        CMP #$0F
        BNE .HDR
        LDA CURLO
        CMP #$FC
        BCS .EARLYCLOSE
.EARLYCLOSE JMP $2537         ; APPENDSCAN.CLOSED
.HDR    LDY #$03
        LDA (SPLO),Y
        STA CANLO
        INY
        LDA (SPLO),Y
        STA CANHI
        ORA CANLO
        BEQ .EARLYCLOSE
        LDA CANHI
        BNE .ADD
        LDA CANLO
        CMP #$05
        BCC .EARLYCLOSE

.ADD    LDA CURLO
        CLC
        ADC CANLO
        STA CURLO
        LDA CURHI
        ADC CANHI
        STA CURHI
        BCS .EARLYCLOSE
        CMP #$10
        BCC .LOOP
        BNE .EARLYCLOSE
        LDA CURLO
        BEQ .EARLYCLOSE
        BRA .EARLYCLOSE

.TAIL   ; A tail is appendable only when it stays erased through $xFFF.
.TCHECK LDA SPHI
        CMP #$1A
        BEQ .TCLEAN
        LDY #$00
        LDA (SPLO),Y
        CMP #$FF
        BNE .EARLYCLOSE
        INC SPLO
        BNE .TCHECK
        INC SPHI
        BRA .TCHECK

.TCLEAN LDA #$00
        SEC
        SBC CURLO
        STA TAILLO
        LDA #$10
        SBC CURHI
        STA TAILHI
        LDA TAILHI
        CMP LENHI
        BCC .SHORT
        BNE .FOUND
        LDA TAILLO
        CMP LENLO
        BCC .SHORT

.FOUND  LDA CURLO
        STA DSTLO
        LDA SECHI
        CLC
        ADC CURHI
        STA DSTHI
        LDA #$02
        STA ATRACE
        BRA .REPORT

.SHORT  LDA #$01
        STA ATRACE
        BRA .REPORT

.CLOSED STZ ATRACE

.REPORT LDX #$9D              ; MAUTOPFX
        LDY #$25
        JSR $20A0
        LDA SECHI
        CLC
        ADC CURHI
        JSR $20BF
        LDA CURLO
        JSR $20BF

        LDA ATRACE
        BEQ .RCLOSED
        CMP #$01
        BEQ .RSHORT

.RFOUND LDX #$C6              ; MAUTOAPPEND
        LDY #$25
        JSR $20A0
        JSR $20D9
        SEC
        RTS

.RCLOSED LDX #$A7             ; MAUTOCLOSED
        LDY #$25
        JSR $20A0
        JSR $20D9
        CLC
        RTS

.RSHORT LDX #$AF              ; MAUTOTAIL
        LDY #$25
        JSR $20A0
        LDA TAILHI
        JSR $20BF
        LDA TAILLO
        JSR $20BF
        LDX #$B7              ; MAUTOSHORT
        LDY #$25
        JSR $20A0
        LDA LENHI
        JSR $20BF
        LDA LENLO
        JSR $20BF
        JSR $20D9
        CLC
        RTS

MAUTOPFX    DB 'A','U','T','O',' ','B','0',':','$',0
MAUTOCLOSED DB ' ','C','L','O','S','E','D',0
MAUTOTAIL   DB ' ','T','A','I','L','=','$',0
MAUTOSHORT  DB ' ','S','H','O','R','T',';',' ','N','E','E','D','=','$',0
MAUTOAPPEND DB ' ','A','P','P','E','N','D',0

        END
