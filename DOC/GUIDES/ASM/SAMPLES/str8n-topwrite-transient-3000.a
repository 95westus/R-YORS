; STR8N-TOPWRITE-TRANSIENT-3000.A
; SELF-CONTAINED STR8-N TOP-SECTOR WRITER.
; ASSEMBLE WITH ASM-F2. NO SEPARATE STR8-TOP-STAGE S19 LOAD NEEDED.
;
; ENTRY POINTS AFTER ASSEMBLY:
;   G 3000  COPY EMBEDDED IMAGE $4000-$4FFF TO $0A00-$19FF
;   G 3003  ERASE/PROGRAM/VERIFY BANK 3 $F000-$FFFF FROM $0A00
;
; STATUS:
;   $1A00 = MODE, $00 STAGE OR $01 PROGRAM
;   $1A01 = $AC OK
;   $1A01 = $E0 STAGE COPY/VERIFY MISMATCH
;   $1A01 = $E1 ERASE TIMEOUT
;   $1A01 = $E2 PROGRAM TIMEOUT
;   $1A01 = $E3 VERIFY MISMATCH
;   $1A02/$1A03 = FAIL ADDRESS WHEN AVAILABLE
;
; FACE CHECK: ROM $F979 MAPS TO RAM $1379.
; PROMPT CHECK: ROM $F9AE MAPS TO RAM $13AE.
;
        ORG $3000

STAGE   JMP TSTAGE
PROG    JMP TPROG

MODE    EQU $1A00
STAT    EQU $1A01
FLO     EQU $1A02
FHI     EQU $1A03
SPLO    EQU $C8
SPHI    EQU $C9
DPLO    EQU $CA
DPHI    EQU $CB

CSTR    EQU $8598
HEXB    EQU $859E
HEXW    EQU $85A1
CRLF    EQU $85A9
WTRAY   EQU $0200

TSTAGE  LDX #<MSTG
        LDY #>MSTG
        JSR PL
        STZ MODE
        STZ STAT
        STZ FLO
        STZ FHI
        JSR COPYI
        JSR VSTG
        BCC STGERR
        LDA #$AC
        STA STAT
        JMP PRSTAT
STGERR  LDA #$E0
        STA STAT
        JMP PRSTAT

TPROG   LDX #<MPRG
        LDY #>MPRG
        JSR PL
        LDA #$01
        STA MODE
        STZ STAT
        STZ FLO
        STZ FHI
        JSR CPYW
        JSR WTRAY
        JMP PRSTAT

COPYI   STZ SPLO
        LDA #$40
        STA SPHI
        STZ DPLO
        LDA #$0A
        STA DPHI
        LDX #$10
CIPAGE  LDY #$00
CIBYTE  LDA (SPLO),Y
        STA (DPLO),Y
        INY
        BNE CIBYTE
        INC SPHI
        INC DPHI
        DEX
        BNE CIPAGE
        RTS

VSTG    STZ SPLO
        LDA #$40
        STA SPHI
        STZ DPLO
        LDA #$0A
        STA DPHI
        LDX #$10
VSPAGE  LDY #$00
VSBYTE  LDA (SPLO),Y
        CMP (DPLO),Y
        BNE VSFAIL
        INY
        BNE VSBYTE
        INC SPHI
        INC DPHI
        DEX
        BNE VSPAGE
        SEC
        RTS
VSFAIL  TYA
        STA FLO
        LDA DPHI
        STA FHI
        CLC
        RTS

CPYW    LDA #<WSTART
        STA SPLO
        LDA #>WSTART
        STA SPHI
        STZ DPLO
        LDA #$02
        STA DPHI
        LDX #$02
CWPAGE  LDY #$00
CWBYTE  LDA (SPLO),Y
        STA (DPLO),Y
        INY
        BNE CWBYTE
        INC SPHI
        INC DPHI
        DEX
        BNE CWPAGE
        RTS

PRSTAT  LDA STAT
        CMP #$AC
        BNE PRERR
        LDX #<MOK
        LDY #>MOK
        JSR PL
        LDA STAT
        SEC
        RTS
PRERR   LDX #<MERR
        LDY #>MERR
        JSR PRC
        LDA STAT
        JSR HEXB
        LDX #<MAT
        LDY #>MAT
        JSR PRC
        LDA FHI
        LDX FLO
        JSR HEXW
        JSR CRLF
        LDA STAT
        CLC
        RTS

PL      JSR PRC
        JMP CRLF
PRC     JMP CSTR

; RAM worker copied to $0200. No ROM calls while flash is busy.
WSTART  PHP
        SEI
        LDA #$EE
        TRB $7FEC
        LDA #$EE
        TSB $7FEC

        STZ $D1
        LDA #$F0
        STA $D2
        LDA #$AA
        STA $D555
        LDA #$55
        STA $AAAA
        LDA #$80
        STA $D555
        LDA #$AA
        STA $D555
        LDA #$55
        STA $AAAA
        LDA #$30
        LDY #$00
        STA ($D1),Y

        STZ $D4
        STZ $D5
        LDA #$08
        STA $D6
WEPOLL  LDY #$00
        LDA ($D1),Y
        CMP #$FF
        BEQ WEROK
        DEC $D4
        BNE WEPOLL
        DEC $D5
        BNE WEPOLL
        DEC $D6
        BNE WEPOLL
        LDA #$E1
        STA STAT
        LDA #$F0
        STA $D555
        LDA #$EE
        TRB $7FEC
        LDA #$EE
        TSB $7FEC
        PLP
        RTS

WEROK   STZ $D1
        LDA #$F0
        STA $D2
        STZ $CF
        LDA #$0A
        STA $D0
WPBYTE  LDY #$00
        LDA ($CF),Y
        CMP #$FF
        BEQ WPNEXT
        STA $D3
        LDA #$AA
        STA $D555
        LDA #$55
        STA $AAAA
        LDA #$A0
        STA $D555
        LDA $D3
        STA ($D1),Y
        STZ $D4
        STZ $D5
        LDA #$02
        STA $D6
WPPOLL  LDY #$00
        LDA ($D1),Y
        CMP $D3
        BEQ WPNEXT
        DEC $D4
        BNE WPPOLL
        DEC $D5
        BNE WPPOLL
        DEC $D6
        BNE WPPOLL
        LDA #$E2
        STA STAT
        LDA $D1
        STA FLO
        LDA $D2
        STA FHI
        BRA WRESET

WPNEXT  INC $D1
        INC $CF
        BNE WPBYTE
        INC $D2
        INC $D0
        LDA $D0
        CMP #$1A
        BNE WPBYTE

        STZ $D1
        LDA #$F0
        STA $D2
        STZ $CF
        LDA #$0A
        STA $D0
WVPAGE  LDY #$00
WVBYTE  LDA ($D1),Y
        CMP ($CF),Y
        BNE WVFAIL
        INY
        BNE WVBYTE
        INC $D2
        INC $D0
        LDA $D0
        CMP #$1A
        BNE WVPAGE
        LDA #$AC
        STA STAT
        LDA #$F0
        STA $D555
        PLP
        RTS

WVFAIL  LDA #$E3
        STA STAT
        TYA
        STA FLO
        LDA $D2
        STA FHI

WRESET  LDA #$F0
        STA $D555
        LDA #$EE
        TRB $7FEC
        LDA #$EE
        TSB $7FEC
        PLP
        RTS

MSTG    DB 'T','W',' ','S','T','G',$00
MPRG    DB 'T','W',' ','P','R','G',$00
MOK     DB 'T','W',' ','O','K',$00
MERR    DB 'T','W',' ','E','R','R','=','$',$00
MAT     DB ' ','@','=','$',$00

        ORG $4000
; EMBEDDED TOP SECTOR IMAGE. ROM $F000-$FFFF.
