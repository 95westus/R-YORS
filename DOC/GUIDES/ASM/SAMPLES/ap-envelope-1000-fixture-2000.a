; EXPECT PACKAGE $3000 TO REPORT L=$1000.

        ORG $2000
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $FF,$A5
        DS $EF,$A5
        END
