; STR8-RESTORE-NONERASED-3000.A
; GUARDED LOWER-SECTOR RESTORE-OVER-NONERASED-BYTES PROOF.
;
; ENTRY $3000 PREPARES THE COLLISION. ENTRY $3003 VERIFIES THE RESTORE.
; CHANGE ARM FROM $00 TO $A5 ONLY AFTER READING THE TEST CARD.
;
; PREP STAGES BANK 2 $9000-$9FFF, COMPLEMENTS BYTE $9FF0 IN THE
; STAGED IMAGE, THEN PROGRAMS THAT IMAGE INTO BANK 3. THE TARGET BYTE
; IS THEREFORE NONERASED AND DELIBERATELY DIFFERS FROM THE SOURCE.
;
; THE OPERATOR THEN RUNS THE REAL STR8 `2` RESTORE, ACCEPTS B2->B3,
; AND DECLINES FLASH C000-FFFF. THAT REPLACES BANK 3 $8000-$BFFF.
; VERIFY STAGES BANK 2 $9000 AGAIN AND COMPARES ALL 4096 BYTES WITH
; THE NOW-VISIBLE BANK 3 SECTOR.
;
; WARNING: PREP ERASES/PROGRAMS BANK 3 $9000-$9FFF. THE STR8 RESTORE
; THEN ERASES/PROGRAMS ALL BANK 3 $8000-$BFFF, INCLUDING FLASH ASM.
; KEEP A PROGRAMMER IMAGE AND THE CURRENT ASM-F2 S19 READY.
;
; STATUS $1A00:
;   $AC PASS (`PHASE` DISTINGUISHES PREP FROM VERIFY)
;   $E0 NOT ARMED
;   $E1 SOURCE STAGE FAILED
;   $E2 POISON PROGRAM/VERIFY FAILED
;   $E3 POISON BYTE READBACK FAILED
;   $E4 VERIFY SOURCE STAGE FAILED
;   $E5 RESTORED SECTOR COMPARE FAILED
;
; RESULT ROW $1A00-$1A07:
;   STATUS PHASE ORIGINAL POISON FAIL-LO FAIL-PAGE SRC-BANK SECTOR-HI
;   PHASE=$50 AFTER PREP; PHASE=$56 AFTER VERIFY.

        ORG $3000

PREP    JMP DOPREP
VERIFY  JMP DOVERIFY

ARM     EQU $00
SRCBANK EQU $02
DSTBANK EQU $03
SECTOR  EQU $90
STAGEHI EQU $0A
STGBYTE EQU $19F0
DSTBYTE EQU $9FF0

STAT    EQU $1A00
PHASE   EQU $1A01
ORIG    EQU $1A02
POISON  EQU $1A03
FAILLO  EQU $1A04
FAILPG  EQU $1A05
METASRC EQU $1A06
METASEC EQU $1A07

SPLO    EQU $C8
SPHI    EQU $C9
DPLO    EQU $CA
DPHI    EQU $CB

STR8SVC EQU $F003
MARKSEC EQU $1FE9
SRCSEL  EQU $1FEE
DSTSEL  EQU $1FEF
MODE    EQU $1FF0
STAGEBF EQU $1FF6
M_PROG  EQU $05
M_STAGE EQU $06

DOPREP  STZ STAT
        STZ PHASE
        STZ ORIG
        STZ POISON
        STZ FAILLO
        STZ FAILPG
        LDA #SRCBANK
        STA METASRC
        LDA #SECTOR
        STA METASEC
        LDA #ARM
        CMP #$A5
        BEQ PARMED
        LDA #$E0
        STA STAT
        CLC
        RTS

PARMED  LDA #SRCBANK
        STA SRCSEL
        LDA #SECTOR
        STA MARKSEC
        LDA #STAGEHI
        STA STAGEBF
        LDA #M_STAGE
        STA MODE
        JSR STR8SVC
        BCS PSTAGED
        LDA #$E1
        STA STAT
        CLC
        RTS

PSTAGED LDA STGBYTE
        STA ORIG
        EOR #$FF
        STA POISON
        STA STGBYTE

        LDA #DSTBANK
        STA DSTSEL
        LDA #SECTOR
        STA MARKSEC
        LDA #STAGEHI
        STA STAGEBF
        LDA #M_PROG
        STA MODE
        JSR STR8SVC
        BCS PPROGED
        LDA #$E2
        STA STAT
        CLC
        RTS

PPROGED LDA DSTBYTE
        CMP POISON
        BEQ PREADY
        LDA #$E3
        STA STAT
        CLC
        RTS

PREADY  LDA #$50
        STA PHASE
        LDA #$AC
        STA STAT
        SEC
        RTS

DOVERIFY STZ STAT
        STZ FAILLO
        STZ FAILPG
        LDA #$56
        STA PHASE
        LDA #SRCBANK
        STA METASRC
        LDA #SECTOR
        STA METASEC
        LDA #SRCBANK
        STA SRCSEL
        LDA #SECTOR
        STA MARKSEC
        LDA #STAGEHI
        STA STAGEBF
        LDA #M_STAGE
        STA MODE
        JSR STR8SVC
        BCS VSTAGED
        LDA #$E4
        STA STAT
        CLC
        RTS

VSTAGED STZ SPLO
        LDA #STAGEHI
        STA SPHI
        STZ DPLO
        LDA #SECTOR
        STA DPHI

VPAGE   LDY #$00
VBYTE   LDA (SPLO),Y
        CMP (DPLO),Y
        BNE VBAD
        INY
        BNE VBYTE
        INC SPHI
        INC DPHI
        INC FAILPG
        LDA FAILPG
        CMP #$10
        BNE VPAGE

        STZ FAILLO
        STZ FAILPG
        LDA #$AC
        STA STAT
        SEC
        RTS

VBAD    TYA
        STA FAILLO
        LDA #$E5
        STA STAT
        CLC
        RTS

        END
