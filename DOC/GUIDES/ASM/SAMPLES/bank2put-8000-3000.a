; BANK2PUT-8000-3000.A
; BOARD-BUILDABLE AP ENVELOPE INSTALLER FOR BANK 2 $8000.
;
; ASSEMBLE WITH FLASH ASM, EXIT SEAL WITH '.', THEN RUN G 3000.
; BEFORE RUNNING, BUILD THE AP ENVELOPE IN RAM, USUALLY:
;   PACKAGE $3200
;
; THIS PRESERVES THE REST OF THE $8000-$8FFF 4K SECTOR:
;   BANK 2 $8000 SECTOR -> $0A00 STAGING BUFFER
;   OVERLAY AP ENVELOPE FROM $3200 AT SECTOR OFFSET $0000
;   PROGRAM STAGED SECTOR BACK TO BANK 2
;
; AFTER SUCCESS, RUN THE STORED PACKAGE WITH:
;   AP B2 $8000 $4800
;
; STATUS:
;   $1A00 = $AC OK
;   $1A00 = $E0 BAD BANK OR DST
;   $1A00 = $E1 STAGE-COPY FAILED
;   $1A00 = $E2 BAD AP HEADER/LENGTH
;   $1A00 = $E3 AP CROSSES 4K SECTOR
;   $1A00 = $E4 PROGRAM/VERIFY FAILED

        ORG $3000

B2      EQU $02
PKG     EQU $3200
DST     EQU $8000

PKGSIG0 EQU PKG
PKGSIG1 EQU PKG+1
PKGLENL EQU PKG+3
PKGLENH EQU PKG+4

STAT    EQU $1A00
LENLO   EQU $1A01
LENHI   EQU $1A02
SPLO    EQU $C8
SPHI    EQU $C9
DPLO    EQU $CA
DPHI    EQU $CB

STR8_SERVICE EQU $F003
STR8_MARK_SECTOR_HI EQU $1FE9
STR8_COPY_SRC_BANK EQU $1FEE
STR8_COPY_DST_BANK EQU $1FEF
STR8_COPY_MODE EQU $1FF0
STR8_STAGE_BUF_HI EQU $1FF6
MODE_PROGRAM_STAGED EQU $05
MODE_STAGE_BANK_SECTOR EQU $06

RUN     STZ STAT
        LDA #B2
        CMP #$03
        BCC CFGDST
BADCFG  LDA #$E0
        STA STAT
        RTS

CFGDST  LDA #>DST
        CMP #$80
        BCS CFGOK
        BRA BADCFG

CFGOK   LDA #B2
        STA STR8_COPY_SRC_BANK
        LDA #>DST
        AND #$F0
        STA STR8_MARK_SECTOR_HI
        LDA #$0A
        STA STR8_STAGE_BUF_HI
        LDA #MODE_STAGE_BANK_SECTOR
        STA STR8_COPY_MODE
        JSR STR8_SERVICE
        BCS STAGED
STAGEFAIL LDA #$E1
        STA STAT
        RTS

STAGED  LDA PKGSIG0
        CMP #'A'
        BEQ SIG0OK
BADAP   LDA #$E2
        STA STAT
        RTS

SIG0OK  LDA PKGSIG1
        CMP #'P'
        BNE BADAP
        LDA PKGLENL
        STA LENLO
        LDA PKGLENH
        STA LENHI
        ORA LENLO
        BEQ BADAP

        LDA #<PKG
        STA SPLO
        LDA #>PKG
        STA SPHI
        LDA #<DST
        STA DPLO
        LDA #>DST
        AND #$0F
        CLC
        ADC #$0A
        STA DPHI

COPY    LDA LENLO
        ORA LENHI
        BEQ COPIED
        LDY #$00
        LDA (SPLO),Y
        STA (DPLO),Y
        INC SPLO
        BNE CDST
        INC SPHI
CDST    INC DPLO
        BNE CCOUNT
        INC DPHI
CCOUNT  DEC LENLO
        LDA LENLO
        CMP #$FF
        BNE CCHK
        DEC LENHI
CCHK    LDA LENLO
        ORA LENHI
        BEQ COPIED
        LDA DPHI
        CMP #$1A
        BCC COPY
        LDA #$E3
        STA STAT
        RTS

COPIED  LDA #B2
        STA STR8_COPY_DST_BANK
        LDA #>DST
        AND #$F0
        STA STR8_MARK_SECTOR_HI
        LDA #$0A
        STA STR8_STAGE_BUF_HI
        LDA #MODE_PROGRAM_STAGED
        STA STR8_COPY_MODE
        JSR STR8_SERVICE
        BCC PROGFAIL
        LDA #$AC
        STA STAT
        RTS

PROGFAIL LDA #$E4
        STA STAT
        RTS

        END
