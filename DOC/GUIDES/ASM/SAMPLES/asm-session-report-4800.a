        ORG $4800

; ZP: $00/$01 PTR, $02 SLOT, $03 COUNT, $04 TMP.
; FLASH ASM OUTPUT HELPERS: $8518 BYTE, $851E CSTR, $8524 HEXB,
; $8527 HEXW AX, $852F CRLF.

START   LDX #<M0
