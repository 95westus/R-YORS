        LDA $5122
        JSR PBF
        LDA $5173
        JSR PBF
        LDA $523D
        JSR PBF
        LDA $542F
        JSR PBF
        LDA $5432
        JSR PBF
        JSR $852F
        LDX #<M13
        LDY #>M13
        JSR PRC
        LDA $5434
