PFIX    LDX #<M9
        LDY #>M9
        JSR PL
        LDX #<M10
        LDY #>M10
        JSR PL
        LDX #$00
PFIXL   CPX $5429
        BEQ PFIXD
        JSR PFIXR
        LDX $02
        INX
        BRA PFIXL
PFIXD   RTS

PFIXR   STX $02
        TXA
        JSR PBF
        LDX $02
        LDA $5E8E,X
        JSR PBF
