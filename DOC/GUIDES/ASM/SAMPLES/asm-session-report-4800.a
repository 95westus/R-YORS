        JSR PWF
        LDA $543D
        LDX $543C
        JSR PW
        JMP $852F

PSYM    LDX #<M7
        LDY #>M7
        JSR PL
        LDX #<M8
        LDY #>M8
        JSR PL
        LDX #$00
PSYML   CPX $5428
        BEQ PSYMD
        JSR PSYMR
        LDX $02
        INX
        BRA PSYML
PSYMD   RTS

PSYMR   STX $02
        TXA
        JSR PBF
        LDX $02
        LDA $548C,X
        JSR PBF
        LDY $02
        LDA $5554,Y
        LDX $552C,Y
        JSR PWF
        JSR SP
        LDX $02
        LDA $54DC,X
        JSR PBF
        LDX $02
        LDA $5504,X
        JSR PBF
        LDX $02
