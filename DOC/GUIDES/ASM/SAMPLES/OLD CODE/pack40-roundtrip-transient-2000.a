; PACK40-ROUNDTRIP-TRANSIENT-2000.A
; ASM V1 PACK40 ROUND TRIP.
; ASSEMBLE WITH ASM. RUN G 2000.
; PASS: $3040=$AC. PACKED AT $3000. UNPACKED AT $3020.
; TABLE BUDGET: 29 GLOBALS, MAX 7 LOCALS PER SCOPE.

        ORG $2000

; ZP USE: $30/$31 SRC, $32/$33 DST, $34-$3D WORK.

PBUF    EQU $3000
UBUF    EQU $3020
STAT    EQU $3040

START   JSR INIT
        JSR SETPACK
        JSR PACK
        BCS .PACKOK
        LDA #$E1
        JMP FAIL
.PACKOK LDA $3B
        STA $3041
        LDA $3C
        STA $3042
        JSR CHKPACK
        BCS .PCHKOK
        LDA #$E2
        JMP FAIL
.PCHKOK JSR SETUNP
        JSR UNPACK
        BCS .UNPOK
        LDA #$E3
        JMP FAIL
.UNPOK  LDA $3C
        STA $3042
        JSR CHKUNP
        BCS PASS
        LDA #$E4
        JMP FAIL

PASS    LDA #$AC
        STA STAT
        SEC
        RTS

FAIL    STA STAT
        CLC
        RTS

INIT    STZ STAT
        STZ $3041
        STZ $3042
        LDX #$1F
.CLR    STZ PBUF,X
        STZ UBUF,X
        DEX
        BPL .CLR
        RTS

SETPACK LDA #<TEXT
        STA $30
        LDA #>TEXT
        STA $31
        LDA #<PBUF
        STA $32
        LDA #>PBUF
        STA $33
        RTS

SETUNP  LDA #<PBUF
        STA $30
        LDA #>PBUF
        STA $31
        LDA #<UBUF
        STA $32
        LDA #>UBUF
        STA $33
        RTS

CHKPACK LDA $3B
        CMP #$10
        BNE .BAD
        LDX #$00
.LOOP   LDA PBUF,X
        CMP PACKED,X
        BNE .BAD
        INX
        CPX #$10
        BNE .LOOP
        SEC
        RTS
.BAD    CLC
        RTS

CHKUNP  LDA $3C
        CMP #$16
        BNE .BAD
        LDX #$00
.LOOP   LDA UBUF,X
        CMP EXPECT,X
        BNE .BAD
        INX
        CPX #$17
        BNE .LOOP
        SEC
        RTS
.BAD    CLC
        RTS

PACK    STZ $3B
        STZ $3C
.GROUP  STZ $34
        STZ $35
        STZ $36
        JSR RCD
        BCC .FAIL
        BEQ .DONE
        STA $34
        JSR RCD
        BCC .FAIL
        BEQ .EMIT
        STA $35
        JSR RCD
        BCC .FAIL
        BEQ .EMIT
        STA $36
.EMIT   LDA $34
        LDX $35
        LDY $36
        JSR P3
        BCC .FAIL
        JSR WWD
        BCC .FAIL
        BRA .GROUP
.DONE   SEC
        RTS
.FAIL   CLC
        RTS

UNPACK  LDA $3B
        STA $3D
        AND #$01
        BNE .FAIL
        STZ $3C
.LOOP   LDA $3D
        BEQ .DONE
        JSR RWD
        JSR U3
        BCC .FAIL
        STA $34
        STX $35
        STY $36
        LDA $34
        BEQ .DONE
        JSR WCD
        BCC .FAIL
        LDA $35
        BEQ .DONE
        JSR WCD
        BCC .FAIL
        LDA $36
        BEQ .DONE
        JSR WCD
        BCC .FAIL
        BRA .LOOP
.DONE   JSR WNUL
        SEC
        RTS
.FAIL   CLC
        RTS

RCD     LDY #$00
        LDA ($30),Y
        BEQ .NUL
        JSR A2C
        BCC .FAIL
        PHA
        JSR INCS
        INC $3C
        BNE .OK
        PLA
        BRA .FAIL
.OK     PLA
        SEC
        RTS
.NUL    SEC
        RTS
.FAIL   CLC
        RTS

WCD     JSR C2A
        BCC .FAIL
        LDY #$00
        STA ($32),Y
        JSR INCD
        INC $3C
        BNE .OK
.FAIL   CLC
        RTS
.OK     SEC
        RTS

WNUL    LDA #$00
        LDY #$00
        STA ($32),Y
        RTS

WWD     STY $3A
        TXA
        LDY #$00
        STA ($32),Y
        JSR INCD
        LDA $3A
        LDY #$00
        STA ($32),Y
        JSR INCD
        CLC
        LDA $3B
        ADC #$02
        BCS .FAIL
        STA $3B
        SEC
        RTS
.FAIL   CLC
        RTS

RWD     LDY #$00
        LDA ($30),Y
        TAX
        JSR INCS
        LDY #$00
        LDA ($30),Y
        STA $3A
        JSR INCS
        SEC
        LDA $3D
        SBC #$02
        STA $3D
        LDY $3A
        RTS

A2C     CMP #$00
        BEQ .ZERO
        CMP #'A'
        BCC .DIG
        CMP #'['
        BCS .DIG
        SEC
        SBC #'@'
        SEC
        RTS
.DIG    CMP #'0'
        BCC .UNDER
        CMP #':'
        BCS .UNDER
        SEC
        SBC #'0'
        CLC
        ADC #$1B
        SEC
        RTS
.UNDER  CMP #'_'
        BNE .Q
        LDA #$25
        SEC
        RTS
.Q      CMP #'?'
        BNE .DOT
        LDA #$26
        SEC
        RTS
.DOT    CMP #'.'
        BNE .FAIL
        LDA #$27
        SEC
        RTS
.ZERO   SEC
        RTS
.FAIL   CLC
        RTS

C2A     CMP #$28
        BCS .FAIL
        CMP #$00
        BEQ .ZERO
        CMP #$1B
        BCS .NL
        CLC
        ADC #'@'
        SEC
        RTS
.NL     CMP #$25
        BCS .SPEC
        CLC
        ADC #$15
        SEC
        RTS
.SPEC   CMP #$25
        BNE .NUND
        LDA #'_'
        SEC
        RTS
.NUND   CMP #$26
        BNE .DOT
        LDA #'?'
        SEC
        RTS
.DOT    LDA #'.'
        SEC
        RTS
.ZERO   LDA #$00
        SEC
        RTS
.FAIL   CLC
        RTS

P3      STA $34
        STX $35
        STY $36
        CMP #$28
        BCS .FAIL
        CPX #$28
        BCS .FAIL
        CPY #$28
        BCS .FAIL
        STZ $38
        STA $37
        JSR M40
        LDA $35
        JSR ADDA
        JSR M40
        LDA $36
        JSR ADDA
        LDX $37
        LDY $38
        SEC
        RTS
.FAIL   CLC
        RTS

ADDA    CLC
        ADC $37
        STA $37
        BCC .DONE
        INC $38
.DONE   RTS

M40     LDA $37
        STA $39
        LDA $38
        STA $3A
        ASL $37
        ROL $38
        ASL $37
        ROL $38
        ASL $37
        ROL $38
        LDX #$05
.LOOP   ASL $39
        ROL $3A
        DEX
        BNE .LOOP
        CLC
        LDA $37
        ADC $39
        STA $37
        LDA $38
        ADC $3A
        STA $38
        RTS

U3      STX $37
        STY $38
        CPY #$FA
        BCS .FAIL
        STZ $34
.D1600  LDA $38
        CMP #$06
        BCC .D1DONE
        BNE .S1600
        LDA $37
        CMP #$40
        BCC .D1DONE
.S1600  SEC
        LDA $37
        SBC #$40
        STA $37
        LDA $38
        SBC #$06
        STA $38
        INC $34
        BRA .D1600
.D1DONE STZ $35
.D40    LDA $38
        BNE .S40
        LDA $37
        CMP #$28
        BCC .D4DONE
.S40    SEC
        LDA $37
        SBC #$28
        STA $37
        LDA $38
        SBC #$00
        STA $38
        INC $35
        BRA .D40
.D4DONE LDA $34
        LDX $35
        LDY $37
        SEC
        RTS
.FAIL   CLC
        RTS

INCS    INC $30
        BNE .DONE
        INC $31
.DONE   RTS

INCD    INC $32
        BNE .DONE
        INC $33
.DONE   RTS

TEXT    DB 'A','S','M','_','A','S','M','.'
        DB 'I','N','_','A','S','M','?'
        DB 'P','A','C','K','4','0','X',0

EXPECT  DB 'A','S','M','_','A','S','M','.'
        DB 'I','N','_','A','S','M','?'
        DB 'P','A','C','K','4','0','X',0

PACKED  DB $45,$09,$7B,$E7,$61,$57,$49,$5D
        DB $EE,$78,$2B,$64,$B3,$49,$00,$96

        END
