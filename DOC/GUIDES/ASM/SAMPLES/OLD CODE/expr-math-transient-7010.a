; EXPR-MATH-TRANSIENT-7010.A
; ASM V1 EXPRESSION MATH PROOF.
; ASSEMBLE WITH ASM. RUN G 7010.
; PASS: $7100-$7103 = 5A 02 00 0F.

        ORG $7000+16

OUT     EQU $7100
OUT1    EQU OUT+1
OUT2    EQU OUT+2
OUT3    EQU OUT+3
BASE    EQU $0001
NEXT    EQU BASE+1

START_ADDR
        LDA #$5A
        STA OUT
        LDA #<NEXT
        STA OUT1
        LDA #>NEXT
        STA OUT2
END_ADDR
SIZE    EQU END_ADDR-START_ADDR
        LDA #SIZE
        STA OUT3
        SEC
        RTS

DATA    DB <NEXT,>NEXT,SIZE

        END
