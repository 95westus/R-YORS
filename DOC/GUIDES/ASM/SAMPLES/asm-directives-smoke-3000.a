; ASM V1 DIRECTIVE SMOKE. PASTE VIA ASM FLASH.
; TESTS EQU, DB, DW, DS, FORWARD FIXUPS, LOCAL BRANCH.
; RUN G 3000. EXPECT $3120=$AC.
; D 3100 3118 SHOULD SHOW:
; A5 5A 52 59 34 12 12 00 0B 00 41 00 17 30 2F 30
; EE FF EE FF 44 42 44 57 00
; TABLE BUDGET: 13 GLOBALS, 4 FIXUPS, 1 LOCAL.

        ORG $3000

OUT     EQU $3100
STAT    EQU $3120
COUNT   EQU 25
WORD0   EQU $1234
BYTE0   EQU $5A
PLUS    EQU 10+1
CHAR    EQU 'A'

RUN     LDX #$00
.LOOP   LDA DATA,X
        STA OUT,X
        INX
        CPX #COUNT
        BNE .LOOP
        JSR MARK
        RTS

MARK    LDA #$AC
        STA STAT
        RTS

DATA    DB $A5,BYTE0,'R','Y'
        DW WORD0,$12,PLUS,CHAR
        DB <DATA,>DATA,<ENDD,>ENDD
PAD     DS 4,$EE,$FF
TAIL    DB 'D','B','D','W'
ENDD    DB $00

        END
