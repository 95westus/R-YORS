; ASM-DIRECTIVES-SMOKE-TRANSIENT-3000.A
; ASM V1 DIRECTIVE SMOKE. PASTE VIA ASM FLASH.
; TESTS EQU, DB, DW, DS, FORWARD FIXUPS, LOCAL BRANCH.
; RUN G 3000. EXPECT $3120=$AC.
; D 3100 3118 SHOULD SHOW:
; A5 5A 52 59 34 12 12 00 0B 00 41 00 EE FF EE FF
; 44 42 44 57 00 1A 30 2E 30
; TABLE BUDGET: 14 GLOBALS, 3 FIXUPS, 2 LOCALS.

        ORG $3000

OUT     EQU $3100
STAT    EQU $3120
COUNT   EQU 25
WORD0   EQU $1234
BYTE0   EQU $5A
PLUS    EQU 10+1
CHAR    EQU 'A'

RUN     BRA .COPY
        DB $EA
.COPY   LDX #$00
.LOOP   LDA DATA,X
        STA OUT,X
        INX
        CPX #COUNT
        BNE .LOOP
        JSR MARK
        SEC
        RTS

MARK    LDA #$AC
        STA STAT
        RTS

DATA    DB $A5,BYTE0,'R','Y'
        DW WORD0,$12,PLUS,CHAR
PAD     DS 4,$EE,$FF
TAIL    DB 'D','B','D','W'
ENDD    DB $00
ADDRS   DW DATA,ENDD

        END
