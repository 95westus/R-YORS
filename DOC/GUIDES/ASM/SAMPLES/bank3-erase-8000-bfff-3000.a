; BANK3-ERASE-8000-BFFF-3000.A
; BOARD-BUILDABLE BANK 3 LOW-FLASH ERASE TOOL.
;
; ASSEMBLE WITH FLASH ASM, EXIT SEAL WITH '.', THEN RUN G 3000.
;
; THIS ERASES PHYSICAL BANK 3 $8000-$BFFF, FOUR 4K SECTORS:
;   $8000-$8FFF
;   $9000-$9FFF
;   $A000-$AFFF
;   $B000-$BFFF
;
; USES THE STR8 RESIDENT RAM WORKER THROUGH $F003.
; FILLS $0A00-$19FF WITH $FF.
; PROGRAM-STAGED THEN MEANS ERASE + VERIFY ONLY.
;
; WARNING: THIS DESTROYS FLASH ASM IF IT LIVES IN $8000-$BFFF.
; AFTER SUCCESS, RELOAD ASM WITH L F BEFORE USING ASM AGAIN.
;
; STATUS:
;   $1A00 = $AC OK
;   $1A00 = $E1 ERASE/VERIFY FAILED
;   $1A01 = FAILING SECTOR HIGH BYTE ($80/$90/$A0/$B0)
;   $1A02/$1A03 = STR8 FAIL ADDRESS WHEN AVAILABLE

        ORG $3000

B3      EQU $03
FIRST   EQU $80
LIMIT   EQU $C0

STAT    EQU $1A00
FSEC    EQU $1A01
FLO     EQU $1A02
FHI     EQU $1A03
DPLO    EQU $CA
DPHI    EQU $CB

STR8_SERVICE EQU $F003
STR8_MARK_SECTOR_HI EQU $1FE9
STR8_MARK_ADDR_LO EQU $1FEA
STR8_MARK_ADDR_HI EQU $1FEB
STR8_COPY_DST_BANK EQU $1FEF
STR8_COPY_MODE EQU $1FF0
STR8_STAGE_BUF_HI EQU $1FF6
MODE_PROGRAM_STAGED EQU $05

RUN     STZ STAT
        STZ FSEC
        STZ FLO
        STZ FHI
        JSR FILLFF
        LDA #FIRST
        STA FSEC

SECTOR  LDA #B3
        STA STR8_COPY_DST_BANK
        LDA FSEC
        STA STR8_MARK_SECTOR_HI
        LDA #$0A
        STA STR8_STAGE_BUF_HI
        LDA #MODE_PROGRAM_STAGED
        STA STR8_COPY_MODE
        JSR STR8_SERVICE
        BCC FAIL

        LDA FSEC
        CLC
        ADC #$10
        STA FSEC
        CMP #LIMIT
        BNE SECTOR

        STZ FSEC
        LDA #$AC
        STA STAT
        RTS

FAIL    LDA #$E1
        STA STAT
        LDA STR8_MARK_ADDR_LO
        STA FLO
        LDA STR8_MARK_ADDR_HI
        STA FHI
        LDA STAT
        RTS

FILLFF  STZ DPLO
        LDA #$0A
        STA DPHI
FPAGE   LDY #$00
        LDA #$FF
FBYTE   STA (DPLO),Y
        INY
        BNE FBYTE
        INC DPHI
        LDA DPHI
        CMP #$1A
        BNE FPAGE
        RTS

        END
