; MISSING-IMPORT-ATOMICITY-2000.A
; CURRENT-IMAGE AP LINKER NEGATIVE FIXTURE.
;
; IMPORT ORDER IS DELIBERATE: VALID FIRST, MISSING SECOND.
; AFTER AP $3200 $3000 FAILS WITH $09, BOTH JSR OPERANDS AT
; $3007-$300C MUST STILL BE $FFFF. DO NOT REORDER THE IMPORTS OR CALLS.

        ORG $2000

        IMPORT BIO_FTDI_PUT_CSTR
        IMPORT OIL_MISSING_SYMBOL

MAIN    BRA RUN
        ENTRY MAIN

RUN     LDA #$E4
        STA $5848
        JSR BIO_FTDI_PUT_CSTR
        JSR OIL_MISSING_SYMBOL
        LDA #$AC
        STA $5848
        SEC
        RTS
        END
