; BANKPUT-3000.A
; BOARD-BUILDABLE AP ENVELOPE INSTALLER FOR FLASH BANKS 0-2.
;
; DEFAULTS TARGET BANK 2 FOR OVERLAY INTEGRATION LAYER (OIL) GATE TESTING.
; EDIT BANK, PKG, AND DST ONLY WHEN YOU INTEND A DIFFERENT TARGET, THEN
; ASSEMBLE WITH FLASH ASM, EXIT SEAL WITH '.', THEN RUN G 3000.
; BANK 0-2 IS THE PHYSICAL FLASH BANK. PKG IS A RAM AP ENVELOPE, USUALLY
; WRITTEN BY PACKAGE $3200. DST IS THE BANK-WINDOW ADDRESS WHERE THE AP
; ENVELOPE SHOULD LIVE, FOR EXAMPLE $9000.
;
; THIS PRESERVES THE REST OF THE 4K SECTOR:
;   BANK SECTOR -> $0A00 SECTOR STAGING BUFFER
;   OVERLAY AP ENVELOPE AT DST OFFSET
;   PROGRAM STAGED SECTOR BACK TO BANK
;
; STATUS:
;   $1A00 = $AC OK
;   $1A00 = $E0 BAD BANK OR DST
;   $1A00 = $E1 STAGE-COPY FAILED
;   $1A00 = $E2 BAD AP HEADER/LENGTH
;   $1A00 = $E3 AP CROSSES 4K SECTOR
;   $1A00 = $E4 PROGRAM/VERIFY FAILED

        ORG $3000

BANK    EQU $02
PKG     EQU $3200
DST     EQU $9000

PKGSIG0 EQU PKG
PKGSIG1 EQU PKG+1
PKGLENL EQU PKG+3
PKGLENH EQU PKG+4

STAT    EQU $1A00
LENLO   EQU $1A01
LENHI   EQU $1A02
SPLO    EQU $C8
SPHI    EQU $C9
DPLO    EQU $CA
DPHI    EQU $CB

STR8_SERVICE EQU $F003
STR8_MARK_SECTOR_HI EQU $1FE9
STR8_COPY_SRC_BANK EQU $1FEE
STR8_COPY_DST_BANK EQU $1FEF
STR8_COPY_MODE EQU $1FF0
STR8_STAGE_BUF_HI EQU $1FF6
MODE_PROGRAM_STAGED EQU $05
MODE_STAGE_BANK_SECTOR EQU $06

RUN     STZ STAT
        LDA #BANK
        CMP #$03
        BCC CFGDST
BADCFG  LDA #$E0
        STA STAT
        RTS

CFGDST  LDA #>DST
        CMP #$80
        BCS CFGOK
        BRA BADCFG

CFGOK   LDA #BANK
        STA STR8_COPY_SRC_BANK
        LDA #>DST
        AND #$F0
        STA STR8_MARK_SECTOR_HI
        LDA #$0A
        STA STR8_STAGE_BUF_HI
        LDA #MODE_STAGE_BANK_SECTOR
        STA STR8_COPY_MODE
        JSR STR8_SERVICE
        BCS STAGED
STAGEFAIL LDA #$E1
        STA STAT
        RTS

STAGED  LDA PKGSIG0
        CMP #'A'
        BEQ SIG0OK
BADAP   LDA #$E2
        STA STAT
        RTS

SIG0OK  LDA PKGSIG1
        CMP #'P'
        BNE BADAP
        LDA PKGLENL
        STA LENLO
        LDA PKGLENH
        STA LENHI
        ORA LENLO
        BEQ BADAP

        LDA #<PKG
        STA SPLO
        LDA #>PKG
        STA SPHI
        LDA #<DST
        STA DPLO
        LDA #>DST
        AND #$0F
        CLC
        ADC #$0A
        STA DPHI

COPY    LDA LENLO
        ORA LENHI
        BEQ COPIED
        LDY #$00
        LDA (SPLO),Y
        STA (DPLO),Y
        INC SPLO
        BNE CDST
        INC SPHI
CDST    INC DPLO
        BNE CCOUNT
        INC DPHI
CCOUNT  DEC LENLO
        LDA LENLO
        CMP #$FF
        BNE CCHK
        DEC LENHI
CCHK    LDA LENLO
        ORA LENHI
        BEQ COPIED
        LDA DPHI
        CMP #$1A
        BCC COPY
        LDA #$E3
        STA STAT
        RTS

COPIED  LDA #BANK
        STA STR8_COPY_DST_BANK
        LDA #>DST
        AND #$F0
        STA STR8_MARK_SECTOR_HI
        LDA #$0A
        STA STR8_STAGE_BUF_HI
        LDA #MODE_PROGRAM_STAGED
        STA STR8_COPY_MODE
        JSR STR8_SERVICE
        BCC PROGFAIL
        LDA #$AC
        STA STAT
        RTS

PROGFAIL LDA #$E4
        STA STAT
        RTS

        END
