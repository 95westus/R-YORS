; STR8-HIGHFAIL-INJECT-3000.A
; MAP-GUARDED STR8 HIGH-RESTORE FAILURE-INJECTION PROOF.
;
; ENTRY $3000 RUNS THE TEST AND MUST NOT RETURN.
; ENTRY $3003 VERIFIES THE TOP SECTOR AFTER HARDWARE RESET + WARM HIMON.
; CHANGE ARM FROM $00 TO $A5 ONLY AFTER READING THE TEST CARD.
;
; THIS FIXTURE FIRST PROVES BANK 2 $C000-$FFFF IS BYTE-IDENTICAL TO
; LIVE BANK 3, RETAINING THE EXACT BANK 2 TOP-SECTOR SOURCE IN
; $0A00-$19FF. IT LOADS THE INSTALLED STR8 WORKER THROUGH $F003,
; CHECKS THE CURRENT WORKER PATCH SITE, AND PATCHES THE RAM COPY ONLY.
;
; THE PATCH FORCES CARRY CLEAR AFTER HIGH RESTORE HAS ERASED,
; PROGRAMMED, AND VERIFIED $F000-$FFFF, AS THE SECTOR MARK WRAPS TO
; $00. THE REAL WORKER FAILURE DISPATCH MUST SELECT BANK 3 AND ENTER
; ITS TERMINAL HALT INSTEAD OF RETURNING THROUGH REPLACED ROM.
;
; WARNING: THE TEST ERASES/PROGRAMS ALL BANK 3 $8000-$FFFF FROM
; BANK 2. KEEP A PROGRAMMER IMAGE AND CURRENT ASM-F2 S19 READY.
; BANK 2 C000-FFFF MUST REMAIN THE KNOWN-GOOD COPY; THE FIXTURE
; REFUSES TO WRITE IF THOSE FOUR SECTORS DIFFER FROM LIVE BANK 3.
;
; THIS PROVES THE SOFTWARE FAILURE POLICY AFTER THE F-SECTOR WRITE.
; IT DOES NOT MANUFACTURE A PHYSICAL ERASE/PROGRAM FAILURE INSIDE THE
; LIVE $F000-$FFFF TRANSACTION.
;
; STATUS $1A00:
;   $AC POST-RESET TOP-SECTOR COMPARE PASS
;   $E0 NOT ARMED
;   $E1 BANK STAGE FAILED
;   $E2 INSTALLED RAM WORKER DOES NOT MATCH THE PINNED PATCH SITE
;   $E3 INJECTED HIGH-RESTORE FAILURE ARMED; NO RETURN IS EXPECTED
;   $E4 TOP SECTOR CHANGED
;   $E5 BANK 2/BANK 3 C000-FFFF PREFLIGHT MISMATCH
;   $E6 POST-RESET STATE DOES NOT PROVE THE INJECTION REACHED WRAP $00
;
; RESULT ROW $1A00-$1A07:
;   STATUS FAIL-SEC HOOK FAIL-LO FAIL-PAGE CHECK-SEC SRC-BANK DST-BANK
; SUCCESS AFTER VERIFY: AC 00 5A 00 00 F0 02 03

        ORG $3000

RUN     JMP DORUN
VERIFY  JMP DOVERIFY

ARM     EQU $00
SRCBANK EQU $02
DSTBANK EQU $03
STAGEHI EQU $0A

STAT    EQU $1A00
FAILSEC EQU $1A01
HOOKOK  EQU $1A02
FAILLO  EQU $1A03
FAILPG  EQU $1A04
CHKSEC  EQU $1A05
METASRC EQU $1A06
METADST EQU $1A07

SPLO    EQU $C8
SPHI    EQU $C9
DPLO    EQU $CA
DPHI    EQU $CB

STR8SVC EQU $F003
WORKRUN EQU $0200
PATCH0  EQU $0275
PATCH1  EQU $0276
PATCH2  EQU $0277
PATCH3  EQU $0278
PATCH4  EQU $0279
HOOKDST EQU $04CA

MARKSEC EQU $1FE9
SRCSEL  EQU $1FEE
DSTSEL  EQU $1FEF
MODE    EQU $1FF0
STAGEBF EQU $1FF6
M_HIGH  EQU $03
M_STAGE EQU $06

DORUN   STZ STAT
        STZ FAILSEC
        STZ HOOKOK
        STZ FAILLO
        STZ FAILPG
        STZ CHKSEC
        LDA #SRCBANK
        STA METASRC
        LDA #DSTBANK
        STA METADST
        LDA #ARM
        CMP #$A5
        BEQ HARMED
        LDA #$E0
        STA STAT
        CLC
        RTS

; Require live HIMON and STR8 to be identical in Bank 2 and Bank 3.
HARMED  LDA #$C0
        STA CHKSEC
HCHECK  JSR STAGE2
        BCS HCSTAGED
        JMP HSTGFAIL
HCSTAGED JSR CMPSTAGE
        BCS HCMATCH
        LDA #$E5
        STA STAT
        CLC
        RTS
HCMATCH LDA CHKSEC
        CMP #$F0
        BEQ HTOPSAVE
        CLC
        ADC #$10
        STA CHKSEC
        BRA HCHECK

; The final successful preflight leaves Bank 2's top-sector source in $0A00.
HSTGFAIL LDA #$E1
        STA STAT
        CLC
        RTS

; Refuse to patch any worker except the reviewed current-image layout.
HTOPSAVE LDA PATCH0
        CMP #$8D
        BNE HSIGBAD
        LDA PATCH1
        CMP #$E9
        BNE HSIGBAD
        LDA PATCH2
        CMP #$1F
        BNE HSIGBAD
        LDA PATCH3
        CMP #$D0
        BNE HSIGBAD
        LDA PATCH4
        CMP #$D2
        BNE HSIGBAD
        BRA HSIGOK
HSIGBAD LDA #$E2
        STA STAT
        CLC
        RTS

; Copy a 16-byte absolute hook into unused RAM immediately after the worker.
; Hook bytes:
;   STA $1FE9 / CMP #$00 / BNE RTS / STA $1A01
;   PLA / PLA / JMP $027C / RTS
HSIGOK  LDX #$00
HCPY    LDA HOOKDAT,X
        STA HOOKDST,X
        INX
        CPX #$10
        BNE HCPY

; Replace `STA $1FE9` at $0275 with `JSR $04CA`.
        LDA #$20
        STA PATCH0
        LDA #$CA
        STA PATCH1
        LDA #$04
        STA PATCH2
        LDA #$5A
        STA HOOKOK
        LDA #$E3
        STA STAT

        LDA #SRCBANK
        STA SRCSEL
        LDA #DSTBANK
        STA DSTSEL
        LDA #M_HIGH
        STA MODE
        JMP WORKRUN

; After reset, enter HIMON warm so $0A00-$1A07 survive, then run G 3003.
DOVERIFY LDA STAT
        CMP #$E3
        BNE HBADSTATE
        LDA FAILSEC
        CMP #$00
        BNE HBADSTATE
        LDA HOOKOK
        CMP #$5A
        BNE HBADSTATE

        STZ FAILLO
        STZ FAILPG
        STZ SPLO
        LDA #STAGEHI
        STA SPHI
        STZ DPLO
        LDA #$F0
        STA DPHI
HTPAGE  LDY #$00
HTBYTE  LDA (SPLO),Y
        CMP (DPLO),Y
        BNE HTBAD
        INY
        BNE HTBYTE
        INC SPHI
        INC DPHI
        INC FAILPG
        LDA FAILPG
        CMP #$10
        BNE HTPAGE

        STZ FAILLO
        STZ FAILPG
        LDA #$F0
        STA CHKSEC
        LDA #$AC
        STA STAT
        SEC
        RTS

HTBAD   TYA
        STA FAILLO
        LDA #$E4
        STA STAT
        CLC
        RTS

HBADSTATE LDA #$E6
        STA STAT
        CLC
        RTS

; Stage Bank 2 sector CHKSEC into $0A00-$19FF. Returns Bank 3 selected.
STAGE2  LDA #SRCBANK
        STA SRCSEL
        LDA CHKSEC
        STA MARKSEC
        LDA #STAGEHI
        STA STAGEBF
        LDA #M_STAGE
        STA MODE
        JSR STR8SVC
        RTS

; Compare staged sector with visible Bank 3 sector CHKSEC.
CMPSTAGE STZ FAILLO
        STZ FAILPG
        STZ SPLO
        LDA #STAGEHI
        STA SPHI
        STZ DPLO
        LDA CHKSEC
        STA DPHI
HCPAGE  LDY #$00
HCBYTE  LDA (SPLO),Y
        CMP (DPLO),Y
        BNE HCBAD
        INY
        BNE HCBYTE
        INC SPHI
        INC DPHI
        INC FAILPG
        LDA FAILPG
        CMP #$10
        BNE HCPAGE
        STZ FAILLO
        STZ FAILPG
        SEC
        RTS
HCBAD   TYA
        STA FAILLO
        CLC
        RTS

HOOKDAT DB $8D,$E9,$1F,$C9,$00,$D0,$08,$8D
        DB $01,$1A,$68,$68,$4C,$7C,$02,$60

        END
